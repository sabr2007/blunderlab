# Public — safe to expose to the browser
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Server-only — never expose
SUPABASE_SERVICE_ROLE_KEY=
CRON_SECRET=
OPENAI_API_KEY=

# Phase 2 review pipeline
OPENAI_MODEL=gpt-4o-mini
COACH_TIMEOUT_MS=10000
REVIEW_DAILY_LIMIT=3

# Notes
# - Supabase project must enable "Allow anonymous sign-ins" (Auth > Providers > Anonymous).
#   Phase 2 relies on supabase.auth.signInAnonymously() before any RLS-guarded write.
# - REVIEW_DAILY_LIMIT can be raised locally for demos (e.g. 30) without changing schema.
