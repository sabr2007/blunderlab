{
  "name": "blunderlab",
  "version": "0.1.0",
  "private": true,
  "description": "AI chess coach that turns blunders into a personalized training plan.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "remotion:studio": "remotion studio remotion/index.ts",
    "remotion:render:en": "remotion render remotion/index.ts BlunderLabDemoEN out/blunderlab-demo-en.mp4 --codec=h264 --quality=80",
    "remotion:render:ru": "remotion render remotion/index.ts BlunderLabDemoRU out/blunderlab-demo-ru.mp4 --codec=h264 --quality=80",
    "remotion:still:en": "remotion still remotion/index.ts BlunderLabDemoEN out/blunderlab-demo-en-frame.png --frame=990 --scale=0.25",
    "remotion:still:ru": "remotion still remotion/index.ts BlunderLabDemoRU out/blunderlab-demo-ru-frame.png --frame=990 --scale=0.25",
    "test:e2e": "playwright test",
    "db:types": "pnpm dlx supabase gen types typescript --project-id tsijruonmfrwydtdmpdx --schema public > lib/supabase/database.generated.ts"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-label": "^2.1.1",
    "@radix-ui/react-progress": "^1.1.1",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-tabs": "^1.1.2",
    "@radix-ui/react-tooltip": "^1.1.6",
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "2.47.0",
    "@tailwindcss/postcss": "^4.2.4",
    "@vercel/analytics": "^2.0.1",
    "chess.js": "^1.4.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^11.15.0",
    "geist": "^1.3.1",
    "lucide-react": "^0.469.0",
    "next": "^16.2.4",
    "next-intl": "^4.11.0",
    "openai": "^4.77.0",
    "react": "^19.2.5",
    "react-chessboard": "^5.10.0",
    "react-dom": "^19.2.5",
    "recharts": "^3.8.1",
    "stockfish": "^18.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@fontsource/geist-mono": "^5.2.7",
    "@fontsource/geist-sans": "^5.2.5",
    "@playwright/test": "^1.49.1",
    "@remotion/cli": "^4.0.456",
    "@remotion/tailwind-v4": "^4.0.456",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.10.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "happy-dom": "^16.5.3",
    "postcss": "^8.4.49",
    "remotion": "^4.0.456",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "packageManager": "pnpm@10.0.0",
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  }
}
